---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  current?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Open-source infrastructure for literature-based drug discovery. Robertium reads biomedical papers, extracts structured claims, and surfaces drug repurposing hypotheses.',
  current = '',
  canonical,
  ogImage = '/og/home.png',
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="drug discovery, drug repurposing, biomedical literature, open science, knowledge graph, glioblastoma, epilepsy, hypothesis generation" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <link rel="canonical" href={canonicalURL} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
</head>
<body>
  <Header current={current} />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
