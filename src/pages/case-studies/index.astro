---
import Layout from '../../layouts/Layout.astro';
import { formatDomainName } from '../../lib/format';
import fs from 'node:fs';
import path from 'node:path';

interface CaseStudyMeta {
  slug: string;
  hypothesis_id: number;
  section: 'novel' | 'benchmark';
  title: string;
  drug: { name: string; domain: string | null };
  mediator: { name: string; type: string | null };
  outcome: { name: string; domain: string | null };
  metrics: {
    outreach_score: number | null;
    outreach_quality: string | null;
    ab_count: number | null;
    bc_count: number | null;
  };
}

const dir = path.join(process.cwd(), 'src', 'data', 'case-studies');
const files = fs.readdirSync(dir).filter((f) => f.endsWith('.json'));
const all: CaseStudyMeta[] = files.map(
  (f) => JSON.parse(fs.readFileSync(path.join(dir, f), 'utf-8')) as CaseStudyMeta,
);

// Preserve display order: novel first (carbamazepine, curcumin, ketogenic),
// then benchmark (ketamine, fingolimod).
const ORDER = [
  'carbamazepine-kras-pancreatic-cancer',
  'curcumin-tdp43-als',
  'ketogenic-diet-sod1-als',
  'ketamine-nmda-chronic-pain',
  'fingolimod-hmgb1-als',
];
const sortFn = (a: CaseStudyMeta, b: CaseStudyMeta) =>
  ORDER.indexOf(a.slug) - ORDER.indexOf(b.slug);

const novelCases = all.filter((c) => c.section === 'novel').sort(sortFn);
const benchmarkCases = all.filter((c) => c.section === 'benchmark').sort(sortFn);

const fmtDomain = (d: string | null) =>
  d ? formatDomainName(d) : 'cross-domain';

const renderCard = (c: CaseStudyMeta) => ({
  href: `/case-studies/${c.slug}/`,
  drug: c.drug.name,
  mediator: c.mediator.name,
  outcome: c.outcome.name,
  drugDomain: fmtDomain(c.drug.domain),
  outcomeDomain: fmtDomain(c.outcome.domain),
  score: c.metrics.outreach_score,
  quality: c.metrics.outreach_quality,
  ab: c.metrics.ab_count ?? 0,
  bc: c.metrics.bc_count ?? 0,
  id: c.hypothesis_id,
});
---
<Layout
  title="Case studies — Robertium featured hypothesis deep-dives"
  description="Featured hypothesis case studies from the Robertium catalog: deep-dives into top novel candidates and benchmark validation hits, with evidence chains and biological context."
  current="case-studies"
  ogImage="/og/home.png"
>
  <div class="cs-draft-banner">
    <div class="container">
      <strong>DRAFT</strong>
      These case-study pages are in active drafting. Biological interpretation is pending review
      by the author — placeholder text is visible throughout. Quantitative data is final.
    </div>
  </div>

  <section class="hyp-hero">
    <div class="container">
      <h1>Featured hypothesis case studies</h1>
      <p class="subtitle">
        Deep-dives into selected hypotheses from the Robertium catalog — drug → mediator →
        outcome chains presented as standalone insights with their evidence and limitations.
      </p>
      <p class="csi-todo-intro">
        [TODO Daniel — page intro: <em>2-3 sentences explaining how these five cases were
        selected, what readers should look for, and how the two sections (novel candidates
        vs benchmark hits) differ in their role in the catalog.</em>]
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="csi-section-head">
        <span class="csi-section-eyebrow">Section 1</span>
        <h2>Top novel candidate hypotheses</h2>
      </div>
      <p class="csi-section-body">
        [TODO Daniel — section intro: <em>e.g. "These are hypotheses Robertium discovered that
        have not yet been explored as clinical or therapeutic combinations in the literature.
        Each pairs a drug from one therapeutic area with a disease from another via a shared
        molecular mediator."</em>]
      </p>
      <div class="csi-grid">
        {novelCases.map((c) => {
          const v = renderCard(c);
          return (
            <a class="csi-card csi-card--novel" href={v.href}>
              <div class="csi-card-eyebrow">
                <span class="csi-card-section">Novel candidate</span>
                {v.quality && <span class={`csi-quality csi-quality--${v.quality}`}>{v.quality}</span>}
              </div>
              <div class="csi-card-chain">
                <span class="csi-chain-drug">{v.drug}</span>
                <span class="csi-chain-arrow">→</span>
                <span class="csi-chain-mediator">{v.mediator}</span>
                <span class="csi-chain-arrow">→</span>
                <span class="csi-chain-outcome">{v.outcome}</span>
              </div>
              <div class="csi-card-domains">
                <span class="csi-domain-tag">{v.drugDomain}</span>
                <span class="csi-chain-arrow csi-chain-arrow--small">→</span>
                <span class="csi-domain-tag">{v.outcomeDomain}</span>
              </div>
              <div class="csi-card-footer">
                <span class="csi-card-score">score {v.score != null ? v.score.toFixed(3) : '—'}</span>
                <span class="csi-card-evidence">{v.ab} + {v.bc} papers</span>
                <span class="csi-card-link">Read deep-dive →</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="csi-section-head">
        <span class="csi-section-eyebrow csi-section-eyebrow--benchmark">Section 2</span>
        <h2>Benchmark validation hits</h2>
      </div>
      <p class="csi-section-body">
        [TODO Daniel — section intro: <em>e.g. "These are known drug repurposings that
        Robertium successfully surfaced from literature, demonstrating that the system can
        both discover novel candidates and recover established knowledge. They appear as
        lower-quality entries in the public catalog because the novelty filter recognizes
        their established status — but their recovery is what gives us confidence the
        pipeline isn't only finding noise."</em>]
      </p>
      <div class="csi-grid csi-grid--benchmark">
        {benchmarkCases.map((c) => {
          const v = renderCard(c);
          return (
            <a class="csi-card csi-card--benchmark" href={v.href}>
              <div class="csi-card-eyebrow">
                <span class="csi-card-section csi-card-section--benchmark">Benchmark hit</span>
                {v.quality && <span class={`csi-quality csi-quality--${v.quality}`}>{v.quality}</span>}
              </div>
              <div class="csi-card-chain">
                <span class="csi-chain-drug">{v.drug}</span>
                <span class="csi-chain-arrow">→</span>
                <span class="csi-chain-mediator">{v.mediator}</span>
                <span class="csi-chain-arrow">→</span>
                <span class="csi-chain-outcome">{v.outcome}</span>
              </div>
              <div class="csi-card-domains">
                <span class="csi-domain-tag">{v.drugDomain}</span>
                <span class="csi-chain-arrow csi-chain-arrow--small">→</span>
                <span class="csi-domain-tag">{v.outcomeDomain}</span>
              </div>
              <div class="csi-card-footer">
                <span class="csi-card-score">score {v.score != null ? v.score.toFixed(3) : '—'}</span>
                <span class="csi-card-evidence">{v.ab} + {v.bc} papers</span>
                <span class="csi-card-link">Read deep-dive →</span>
              </div>
            </a>
          );
        })}
      </div>
      <p class="csi-benchmark-foot">
        For the full benchmark validation story — including how the v1 and v2 architectural
        choices were tested — see <a href="/benchmark">/benchmark</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <div class="section-header">
        <div class="section-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <h2>Want the full catalog?</h2>
      </div>
      <p>
        These five case studies are a curated subset. For every cross-domain hypothesis
        Robertium has surfaced — including filtering by drug, mediator, outcome domain,
        or evidence level — see the full
        <a href="/hypotheses" style="color:var(--accent);">catalog</a>. The discovery method is
        described in detail at <a href="/method" style="color:var(--accent);">/method</a>.
      </p>
    </div>
  </section>
</Layout>

<style>
  /* ===== Page-intro TODO block ===== */
  .csi-todo-intro {
    background: var(--state-error-bg);
    border: 1px solid rgba(185, 28, 28, 0.25);
    border-left: 4px solid var(--state-error);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin: var(--space-6) 0 0;
    font-family: var(--font-base);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    max-width: 760px;
  }
  .csi-todo-intro::before {
    content: "Draft — author review pending";
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--state-error);
    margin-bottom: var(--space-3);
  }
  .csi-todo-intro em {
    color: var(--text-secondary);
    font-style: italic;
  }

  /* ===== Section eyebrow + h2 (DrugBank pattern) ===== */
  .csi-section-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .csi-section-eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
  }
  .csi-section-eyebrow--benchmark { color: var(--state-warning); }
  .csi-section-head h2 {
    font-family: var(--font-base);
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    margin: 0;
    line-height: var(--leading-tight);
  }
  .csi-section-body {
    background: var(--state-error-bg);
    border: 1px solid rgba(185, 28, 28, 0.25);
    border-left: 4px solid var(--state-error);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin: 0 0 var(--space-10);
    font-family: var(--font-base);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    max-width: 760px;
  }
  .csi-section-body::before {
    content: "Draft — author review pending";
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--state-error);
    margin-bottom: var(--space-3);
  }
  .csi-section-body em {
    color: var(--text-secondary);
    font-style: italic;
  }

  /* ===== Cards grid (DrugBank-style) ===== */
  .csi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  .csi-grid--benchmark {
    grid-template-columns: repeat(2, 1fr);
    max-width: 880px;
  }
  .csi-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: border-color .15s ease, transform .15s ease, box-shadow .15s ease;
  }
  .csi-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    transform: translateY(-2px);
  }
  .csi-card--benchmark:hover { border-color: var(--state-warning); }
  .csi-card-eyebrow {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
  }
  .csi-card-section {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
  }
  .csi-card-section--benchmark { color: var(--state-warning); }
  .csi-quality {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    padding: var(--space-1) var(--space-3);
    border-radius: 999px;
  }
  .csi-quality--high { background: var(--state-success-bg); color: var(--state-success); }
  .csi-quality--mid  { background: var(--state-warning-bg); color: var(--state-warning); }
  .csi-quality--low  { background: var(--state-error-bg); color: var(--state-error); }
  .csi-card-chain {
    font-family: var(--font-base);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    line-height: var(--leading-snug);
    color: var(--text-primary);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: baseline;
    letter-spacing: var(--tracking-tight);
  }
  .csi-chain-drug { font-weight: var(--weight-bold); color: var(--text-primary); }
  .csi-chain-mediator { font-weight: var(--weight-bold); color: var(--accent); }
  .csi-chain-outcome { color: var(--text-primary); font-weight: var(--weight-bold); }
  .csi-chain-arrow {
    color: var(--text-muted);
    font-size: var(--text-base);
    font-weight: var(--weight-normal);
  }
  .csi-chain-arrow--small { font-size: var(--text-xs); }
  .csi-card-domains {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .csi-domain-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    padding: var(--space-1) var(--space-2);
    background: var(--bg-section);
    color: var(--text-tertiary);
    border-radius: var(--radius-sm);
  }
  .csi-card-footer {
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }
  .csi-card-score {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
  }
  .csi-card-evidence {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }
  .csi-card-link {
    font-weight: var(--weight-semibold);
    color: var(--accent);
  }
  .csi-card--benchmark .csi-card-link { color: var(--state-warning); }

  /* ===== Benchmark footer note ===== */
  .csi-benchmark-foot {
    margin-top: var(--space-8);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    max-width: 720px;
  }
  .csi-benchmark-foot a {
    color: var(--accent);
    text-decoration: none;
    font-weight: var(--weight-medium);
  }
  .csi-benchmark-foot a:hover { color: var(--accent-hover); text-decoration: underline; }

  @media (max-width: 900px) {
    .csi-grid, .csi-grid--benchmark { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .csi-grid, .csi-grid--benchmark { grid-template-columns: 1fr; }
    .csi-section-head h2 { font-size: var(--text-2xl); }
  }
</style>
