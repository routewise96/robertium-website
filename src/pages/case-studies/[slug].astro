---
import Layout from '../../layouts/Layout.astro';
import EvidenceNetwork from '../../components/EvidenceNetwork.astro';
import { formatDomainName } from '../../lib/format';
import fs from 'node:fs';
import path from 'node:path';

interface PmidEntry {
  pmid: string | null;
  title: string;
  doi: string | null;
  year: number | null;
  // Enriched fields (added 2026-05): present on all newly-generated JSONs.
  subject?: string;
  predicate?: string;
  object?: string;
  claim_text?: string;
  confidence?: number;
  extracted_at?: string;
}
type ExternalLinks = Partial<{
  wikipedia: string;
  drugbank: string;
  clinicaltrials: string;
  uniprot: string;
  mesh: string;
}>;

interface CaseStudy {
  slug: string;
  hypothesis_id: number;
  section: 'novel' | 'benchmark';
  title: string;
  drug: { name: string; canonical: string | null; type: string | null; domain: string | null; external_links?: ExternalLinks };
  mediator: { name: string; canonical: string | null; type: string | null; external_links?: ExternalLinks };
  outcome: { name: string; canonical: string | null; type: string | null; domain: string | null; external_links?: ExternalLinks };
  metrics: {
    outreach_score: number | null;
    outreach_quality: string | null;
    ab_count: number | null;
    bc_count: number | null;
    direct_evidence_count: number | null;
    domain_source: string | null;
    domain_target: string | null;
    predicate_ab: string | null;
    predicate_bc: string | null;
    literature_status: string | null;
    clinical_trial_status: string | null;
    clinical_trial_nct_ids: string[];
  };
  evidence: { ab_claims: PmidEntry[]; bc_claims: PmidEntry[] };
  biological_context: Record<string, string>;
  benchmark_context: Record<string, string> | null;
  limitations_paragraph?: string;
  related_hypotheses: Array<{
    id: number;
    drug: string;
    mediator: string;
    outcome: string;
    score: number | null;
    shared: 'drug' | 'mediator';
  }>;
}

export async function getStaticPaths() {
  const dir = path.join(process.cwd(), 'src', 'data', 'case-studies');
  const files = fs.readdirSync(dir).filter((f) => f.endsWith('.json'));
  return files.map((f) => {
    const data = JSON.parse(fs.readFileSync(path.join(dir, f), 'utf-8')) as CaseStudy;
    return { params: { slug: data.slug }, props: { data } };
  });
}

const { data } = Astro.props as { data: CaseStudy };

const fmtDomain = (d: string | null | undefined) =>
  d ? formatDomainName(d) : 'cross-domain';
const fmtPredicate = (p: string | null) => (p ?? 'modulates').replace(/_/g, ' ');

// ===== Chain SVG: auto-size nodes =====
// Approximate text width avoiding canvas/getBBox (this is SSR). Bold sans-
// serif averages ~0.62× font size per character; regular ~0.55×.
const estimateTextWidth = (text: string, fontSize: number, bold: boolean) => {
  const avgCharWidth = (bold ? 0.62 : 0.55) * fontSize;
  return text.length * avgCharWidth;
};

interface NodeLayout {
  width: number;
  line1: string;
  line2: string | null;
  fontSize: number;
}

const NODE_MIN = 200;
const NODE_MAX = 320;
const NODE_PADDING = 32;
const NODE_SINGLE_FONT = 18;
const NODE_WRAP_FONT = 14;

const layoutNode = (text: string): NodeLayout => {
  const innerMax = NODE_MAX - NODE_PADDING * 2; // 256
  const single = estimateTextWidth(text, NODE_SINGLE_FONT, true);
  if (single <= innerMax) {
    const w = Math.max(NODE_MIN, Math.min(NODE_MAX, Math.round(single + NODE_PADDING * 2)));
    return { width: w, line1: text, line2: null, fontSize: NODE_SINGLE_FONT };
  }
  // Need 2-line wrap. Greedy split balancing length.
  const words = text.split(/\s+/).filter(Boolean);
  if (words.length === 1) {
    // Single very-long word: keep at max width, smaller font, single line.
    return { width: NODE_MAX, line1: text, line2: null, fontSize: NODE_WRAP_FONT };
  }
  // Find the split point that minimizes max(line1, line2) length.
  let bestSplit = 1;
  let bestMax = Infinity;
  for (let i = 1; i < words.length; i++) {
    const a = words.slice(0, i).join(' ');
    const b = words.slice(i).join(' ');
    const m = Math.max(a.length, b.length);
    if (m < bestMax) {
      bestMax = m;
      bestSplit = i;
    }
  }
  const line1 = words.slice(0, bestSplit).join(' ');
  const line2 = words.slice(bestSplit).join(' ');
  return { width: NODE_MAX, line1, line2, fontSize: NODE_WRAP_FONT };
};

const drugLayout = layoutNode(data.drug.name);
const mediatorLayout = layoutNode(data.mediator.name);
const outcomeLayout = layoutNode(data.outcome.name);

const ARROW_GAP = 100;
const SVG_MARGIN = 20;
const NODE_HEIGHT = 80;
const NODE_Y = 50;
const NODE_CENTER_Y = NODE_Y + NODE_HEIGHT / 2; // 90
const ARROW_Y = NODE_CENTER_Y;
const ARROW_LINE_INSET = 5; // visual padding between node edge and line start

const drugX = SVG_MARGIN;
const mediatorX = drugX + drugLayout.width + ARROW_GAP;
const outcomeX = mediatorX + mediatorLayout.width + ARROW_GAP;
const drugCenterX = drugX + drugLayout.width / 2;
const mediatorCenterX = mediatorX + mediatorLayout.width / 2;
const outcomeCenterX = outcomeX + outcomeLayout.width / 2;

const arrowAB_X1 = drugX + drugLayout.width + ARROW_LINE_INSET;
const arrowAB_X2 = mediatorX - ARROW_LINE_INSET;
const arrowAB_CenterX = (arrowAB_X1 + arrowAB_X2) / 2;

const arrowBC_X1 = mediatorX + mediatorLayout.width + ARROW_LINE_INSET;
const arrowBC_X2 = outcomeX - ARROW_LINE_INSET;
const arrowBC_CenterX = (arrowBC_X1 + arrowBC_X2) / 2;

const svgWidth = outcomeX + outcomeLayout.width + SVG_MARGIN;
const svgHeight = 220;

// Vertical position helpers: for single-line text the y is centered; for
// 2-line text, line1 is above center and line2 below.
const textY = (layout: NodeLayout, line: 1 | 2): number => {
  const center = NODE_CENTER_Y;
  if (!layout.line2) {
    // Single line — visual center of the line baseline (~+6 of geometric center for 18px font)
    return center + layout.fontSize / 3;
  }
  // Two-line wrap with 4px vertical gap between baselines
  const lineHeight = layout.fontSize * 1.15;
  const baseline = layout.fontSize / 3;
  if (line === 1) return center - lineHeight / 2 + baseline;
  return center + lineHeight / 2 + baseline;
};

const sublabelY = NODE_Y + NODE_HEIGHT + 30; // 160

const score = data.metrics.outreach_score;
const scorePct = score != null ? Math.max(2, Math.min(100, Math.round(score * 100))) : 0;
const quality = data.metrics.outreach_quality ?? 'unknown';
const isBenchmark = data.section === 'benchmark';
const isLimitedEvidence =
  (data.metrics.ab_count ?? 0) < 3 || (data.metrics.bc_count ?? 0) < 3;

const pubmedUrl = (pmid: string | null) =>
  pmid ? `https://pubmed.ncbi.nlm.nih.gov/${encodeURIComponent(pmid)}/` : null;

const sectionLabel = isBenchmark ? 'Benchmark validation hit' : 'Top novel candidate';
const sectionClass = isBenchmark ? 'is-benchmark' : 'is-novel';

// ===== Literature status badge =====
type LitStatus = 'novel_signal' | 'partial_evidence' | 'reproduces_known';
const LIT_BADGE: Record<LitStatus, { label: string; tooltip: string }> = {
  novel_signal: {
    label: 'Novel cross-domain hypothesis',
    tooltip:
      'No direct repurposing or therapy-style PubMed mentions of this drug↔outcome pair: this is a candidate the literature has not yet surfaced.',
  },
  partial_evidence: {
    label: 'Partial evidence baseline',
    tooltip:
      'Direct PubMed mentions of this drug↔outcome pair exist, but without repurposing or therapy framing — the connection is not yet established as a therapeutic claim.',
  },
  reproduces_known: {
    label: 'Established repurposing',
    tooltip:
      'This drug–disease combination already has an established literature with repurposing or therapy framing. Robertium recovered a known signal.',
  },
};
const litBadge =
  data.metrics.literature_status &&
  (data.metrics.literature_status as LitStatus) in LIT_BADGE
    ? LIT_BADGE[data.metrics.literature_status as LitStatus]
    : null;
const litClass = data.metrics.literature_status
  ? `cs-lit-badge--${data.metrics.literature_status}`
  : '';

// ===== Combined references list (dedup by PMID, sort by year desc) =====
type RefEntry = { pmid: string | null; title: string; year: number | null; leg: 'A→B' | 'B→C' };
const refMap = new Map<string, RefEntry>();
for (const c of data.evidence.ab_claims) {
  const key = c.pmid ?? `nopmid-ab-${c.title}`;
  if (!refMap.has(key))
    refMap.set(key, { pmid: c.pmid, title: c.title, year: c.year ?? null, leg: 'A→B' });
}
for (const c of data.evidence.bc_claims) {
  const key = c.pmid ?? `nopmid-bc-${c.title}`;
  if (!refMap.has(key))
    refMap.set(key, { pmid: c.pmid, title: c.title, year: c.year ?? null, leg: 'B→C' });
}
const allRefs = Array.from(refMap.values()).sort(
  (a, b) => (b.year ?? 0) - (a.year ?? 0),
);

// ===== External-link helpers =====
const drugLinks = data.drug.external_links ?? {};
const mediatorLinks = data.mediator.external_links ?? {};
const outcomeLinks = data.outcome.external_links ?? {};
const hasDrugLinks = Object.keys(drugLinks).length > 0;
const hasMediatorLinks = Object.keys(mediatorLinks).length > 0;
const hasOutcomeLinks = Object.keys(outcomeLinks).length > 0;

const DEFAULT_LIMITATIONS =
  'This hypothesis was generated algorithmically through cross-domain ' +
  'literature analysis and has not been experimentally validated. Treat ' +
  'it as a starting point for further investigation, not a therapeutic ' +
  'recommendation. For established knowledge about each entity, refer to ' +
  'the authoritative sources linked above (Wikipedia, DrugBank, UniProt, MeSH).';
const limitations = data.limitations_paragraph ?? DEFAULT_LIMITATIONS;
---
<Layout
  title={`${data.drug.name} → ${data.mediator.name} → ${data.outcome.name} — Robertium case study`}
  description={`Case study of the Robertium hypothesis linking ${data.drug.name} (${fmtDomain(data.drug.domain)}) to ${data.outcome.name} via ${data.mediator.name}. ${isBenchmark ? 'Benchmark validation hit.' : 'Top novel candidate from the cross-domain catalog.'}`}
  current="case-studies"
  ogImage="/og/home.png"
>
  <section class={`cs-hero ${sectionClass}`}>
    <div class="container">
      <a href="/case-studies/" class="cs-back">← Case studies</a>
      <div class="cs-hero-badges">
        <span class={`cs-section-badge cs-section-badge--${data.section}`}>{sectionLabel}</span>
        <span class="cs-id-badge">Hypothesis #{data.hypothesis_id}</span>
        {isBenchmark ? (
          <span class="cs-quality-badge cs-quality-badge--benchmark">Benchmark case</span>
        ) : quality && quality !== 'unknown' ? (
          <span class={`cs-quality-badge cs-quality-badge--${quality}`}>{quality} quality</span>
        ) : null}
      </div>
      <h1>
        {data.drug.name}
        <span class="cs-hero-arrow">→</span>
        <span class="cs-hero-mediator">{data.mediator.name}</span>
        <span class="cs-hero-arrow">→</span>
        {data.outcome.name}
      </h1>
      <p class="cs-hero-sub">
        Cross-domain hypothesis: <strong>{fmtDomain(data.drug.domain)}</strong> drug →
        <strong>{fmtDomain(data.outcome.domain)}</strong> outcome
      </p>

      <figure class="cs-flow-wrap">
        <svg
          class="cs-flow"
          viewBox={`0 0 ${svgWidth} ${svgHeight}`}
          preserveAspectRatio="xMidYMid meet"
          aria-hidden="true"
        >
          <defs>
            <marker id="cs-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="10" markerHeight="10" orient="auto">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--text-tertiary)"/>
            </marker>
          </defs>

          {/* Drug node */}
          <rect x={drugX} y={NODE_Y} width={drugLayout.width} height={NODE_HEIGHT} rx="8" fill="var(--bg-card)" stroke="var(--border-default)" stroke-width="1"/>
          <text x={drugCenterX} y={textY(drugLayout, 1)} text-anchor="middle" font-family="Inter, sans-serif" font-size={drugLayout.fontSize} font-weight="700" fill="var(--text-primary)">{drugLayout.line1}</text>
          {drugLayout.line2 && (
            <text x={drugCenterX} y={textY(drugLayout, 2)} text-anchor="middle" font-family="Inter, sans-serif" font-size={drugLayout.fontSize} font-weight="700" fill="var(--text-primary)">{drugLayout.line2}</text>
          )}
          <text x={drugCenterX} y={sublabelY} text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="var(--text-tertiary)" letter-spacing="0.1em" text-transform="uppercase">DRUG</text>

          {/* A→B predicate + arrow */}
          <text x={arrowAB_CenterX} y={ARROW_Y - 12} text-anchor="middle" font-family="Inter, sans-serif" font-size="12" font-weight="500" fill="var(--text-tertiary)">{fmtPredicate(data.metrics.predicate_ab)}</text>
          <line x1={arrowAB_X1} y1={ARROW_Y} x2={arrowAB_X2} y2={ARROW_Y} stroke="var(--text-tertiary)" stroke-width="1.5" marker-end="url(#cs-arrow)"/>

          {/* Mediator node */}
          <rect x={mediatorX} y={NODE_Y} width={mediatorLayout.width} height={NODE_HEIGHT} rx="8" fill="var(--accent-bg)" stroke="var(--accent-light)" stroke-width="1.5"/>
          <text x={mediatorCenterX} y={textY(mediatorLayout, 1)} text-anchor="middle" font-family="Inter, sans-serif" font-size={mediatorLayout.fontSize} font-weight="700" fill="var(--accent-hover)">{mediatorLayout.line1}</text>
          {mediatorLayout.line2 && (
            <text x={mediatorCenterX} y={textY(mediatorLayout, 2)} text-anchor="middle" font-family="Inter, sans-serif" font-size={mediatorLayout.fontSize} font-weight="700" fill="var(--accent-hover)">{mediatorLayout.line2}</text>
          )}
          <text x={mediatorCenterX} y={sublabelY} text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="var(--accent)" letter-spacing="0.1em" text-transform="uppercase">MEDIATOR{data.mediator.type ? ` · ${data.mediator.type}` : ''}</text>

          {/* B→C predicate + arrow */}
          <text x={arrowBC_CenterX} y={ARROW_Y - 12} text-anchor="middle" font-family="Inter, sans-serif" font-size="12" font-weight="500" fill="var(--text-tertiary)">{fmtPredicate(data.metrics.predicate_bc)}</text>
          <line x1={arrowBC_X1} y1={ARROW_Y} x2={arrowBC_X2} y2={ARROW_Y} stroke="var(--text-tertiary)" stroke-width="1.5" marker-end="url(#cs-arrow)"/>

          {/* Outcome node */}
          <rect x={outcomeX} y={NODE_Y} width={outcomeLayout.width} height={NODE_HEIGHT} rx="8" fill="var(--bg-card)" stroke="var(--border-default)" stroke-width="1"/>
          <text x={outcomeCenterX} y={textY(outcomeLayout, 1)} text-anchor="middle" font-family="Inter, sans-serif" font-size={outcomeLayout.fontSize} font-weight="700" fill="var(--text-primary)">{outcomeLayout.line1}</text>
          {outcomeLayout.line2 && (
            <text x={outcomeCenterX} y={textY(outcomeLayout, 2)} text-anchor="middle" font-family="Inter, sans-serif" font-size={outcomeLayout.fontSize} font-weight="700" fill="var(--text-primary)">{outcomeLayout.line2}</text>
          )}
          <text x={outcomeCenterX} y={sublabelY} text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="var(--text-tertiary)" letter-spacing="0.1em" text-transform="uppercase">OUTCOME</text>
        </svg>
        <figcaption class="cs-flow-caption">
          Figure 1. Hypothesis chain: {data.drug.name} ({fmtPredicate(data.metrics.predicate_ab)}) {data.mediator.name} ({fmtPredicate(data.metrics.predicate_bc)}) {data.outcome.name}.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {(litBadge || isBenchmark) && (
        <div class="cs-quick-badges">
          {litBadge && (
            <span class={`cs-lit-badge ${litClass}`} title={litBadge.tooltip}>
              {litBadge.label}
            </span>
          )}
          {isBenchmark && (
            <span
              class="cs-lit-badge cs-lit-badge--benchmark"
              title="Included as methodology validation against known repurposing literature, not as novel discovery."
            >
              Benchmark validation case
            </span>
          )}
        </div>
      )}

      <div class="cs-facts-grid">
        <div class="cs-facts-card">
          <div class="cs-facts-label">Outreach score</div>
          <div class="cs-facts-value">{score != null ? score.toFixed(3) : '—'}</div>
          <div class="cs-score-bar"><div class="cs-score-fill" style={`width: ${scorePct}%`}></div></div>
        </div>
        <div class="cs-facts-card">
          <div class="cs-facts-label">Evidence A → B</div>
          <div class="cs-facts-value">{data.metrics.ab_count ?? 0}</div>
          <div class="cs-facts-meta">papers</div>
        </div>
        <div class="cs-facts-card">
          <div class="cs-facts-label">Evidence B → C</div>
          <div class="cs-facts-value">{data.metrics.bc_count ?? 0}</div>
          <div class="cs-facts-meta">papers</div>
        </div>
        <div class="cs-facts-card">
          <div class="cs-facts-label">Direct A → C</div>
          <div class="cs-facts-value">{data.metrics.direct_evidence_count ?? 0}</div>
          <div class="cs-facts-meta">papers</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container--narrow">
      <div class="section-header">
        <div class="section-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="12" cy="18" r="3"/><line x1="8.5" y1="7.5" x2="15.5" y2="7.5"/><line x1="7.5" y1="8.5" x2="11" y2="15.5"/><line x1="16.5" y1="8.5" x2="13" y2="15.5"/></svg>
        </div>
        <h2>Evidence network</h2>
      </div>
      <p class="cs-evnet-intro">
        The full set of scientific papers supporting this hypothesis, visualized
        as a force-directed graph. Each gray node is one paper; hover for the
        extracted claim, click to open it on PubMed.
      </p>
      <EvidenceNetwork
        slug={data.slug}
        drug={data.drug.name}
        mediator={data.mediator.name}
        outcome={data.outcome.name}
        predicateAb={data.metrics.predicate_ab ?? 'modulates'}
        predicateBc={data.metrics.predicate_bc ?? 'associated with'}
        abClaims={data.evidence.ab_claims}
        bcClaims={data.evidence.bc_claims}
        abMetric={data.metrics.ab_count}
        bcMetric={data.metrics.bc_count}
      />
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <div class="section-header">
        <div class="section-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        </div>
        <h2>The drug — {data.drug.name}</h2>
      </div>
      <p class="cs-ext-meta">
        Source domain: <strong>{fmtDomain(data.drug.domain)}</strong>
        {data.drug.type && <> · entity type: <code>{data.drug.type}</code></>}
      </p>
      {hasDrugLinks ? (
        <ul class="cs-ext-links">
          {drugLinks.wikipedia && (
            <li><a href={drugLinks.wikipedia} target="_blank" rel="noopener">Wikipedia</a></li>
          )}
          {drugLinks.drugbank && (
            <li><a href={drugLinks.drugbank} target="_blank" rel="noopener">DrugBank</a></li>
          )}
          {drugLinks.clinicaltrials && (
            <li><a href={drugLinks.clinicaltrials} target="_blank" rel="noopener">ClinicalTrials.gov</a></li>
          )}
        </ul>
      ) : (
        <p class="cs-ext-meta">External references not curated for this entity.</p>
      )}
    </div>
  </section>

  <section class="section section--gray">
    <div class="container--narrow">
      <div class="section-header">
        <div class="section-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        </div>
        <h2>The mediator — {data.mediator.name}</h2>
      </div>
      <p class="cs-ext-meta">
        {data.mediator.type && <>Entity type: <code>{data.mediator.type}</code></>}
      </p>
      {hasMediatorLinks ? (
        <ul class="cs-ext-links">
          {mediatorLinks.wikipedia && (
            <li><a href={mediatorLinks.wikipedia} target="_blank" rel="noopener">Wikipedia</a></li>
          )}
          {mediatorLinks.uniprot && (
            <li><a href={mediatorLinks.uniprot} target="_blank" rel="noopener">UniProt</a></li>
          )}
        </ul>
      ) : (
        <p class="cs-ext-meta">External references not curated for this entity.</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <div class="section-header">
        <div class="section-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        </div>
        <h2>The outcome — {data.outcome.name}</h2>
      </div>
      <p class="cs-ext-meta">
        Target domain: <strong>{fmtDomain(data.outcome.domain)}</strong>
        {data.outcome.type && <> · entity type: <code>{data.outcome.type}</code></>}
      </p>
      {hasOutcomeLinks ? (
        <ul class="cs-ext-links">
          {outcomeLinks.wikipedia && (
            <li><a href={outcomeLinks.wikipedia} target="_blank" rel="noopener">Wikipedia</a></li>
          )}
          {outcomeLinks.mesh && (
            <li><a href={outcomeLinks.mesh} target="_blank" rel="noopener">MeSH</a></li>
          )}
        </ul>
      ) : (
        <p class="cs-ext-meta">External references not curated for this entity.</p>
      )}
    </div>
  </section>

  <section class="section section--gray">
    <div class="container--narrow">
      <div class="section-header">
        <div class="section-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h2>Evidence</h2>
      </div>
      {isLimitedEvidence && (
        <p class="cs-evidence-warning">
          Limited evidence base in our current extraction. Treat this hypothesis as a
          starting point for further literature review, not a settled conclusion.
        </p>
      )}

      <div class="cs-evidence-block">
        <h3 class="cs-evidence-head">
          A → B evidence:
          <span class="cs-evidence-chain">{data.drug.name}</span>
