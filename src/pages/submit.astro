---
import Layout from '../layouts/Layout.astro';
import SubmissionForm from '../components/SubmissionForm.astro';
---
<Layout
  title="Submit a hypothesis — Robertium"
  description="Researchers can submit drug-repurposing hypotheses to Robertium. Approved submissions go through the same evidence pipeline as algorithmically generated candidates and are published with your attribution."
  current="submit"
  ogImage="/og/home.png"
>
  <section class="hyp-hero">
    <div class="container">
      <h1>Submit a hypothesis</h1>
      <p class="subtitle">Propose a drug → mediator → outcome chain for the pipeline to evaluate</p>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <div class="section-header">
        <div class="section-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <h2>What to expect</h2>
      </div>
      <p>
        All submissions undergo manual review (typically 24–72 hours). Approved
        hypotheses are processed through Robertium's evidence pipeline —
        PubMed search, structured claim extraction, scoring — and published
        with your attribution alongside the algorithmically generated catalog.
      </p>
      <p>
        Low-evidence submissions (fewer than two supporting papers in PubMed)
        may be returned for clarification. We aim to publish every submission
        that has substantive reasoning behind it, but reserve the right to
        decline ones that are clearly out of scope (homeopathy, unfalsifiable
        claims, manifest commercial conflict).
      </p>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container--narrow">
      <div class="section-header">
        <div class="section-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.5 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V7.5L14.5 2z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <h2>Your submission</h2>
      </div>
      <SubmissionForm />
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <div class="section-header">
        <div class="section-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 019.9-1"/>
          </svg>
        </div>
        <h2>Privacy &amp; what gets published</h2>
      </div>
      <p>
        Submissions are stored in the public
        <a href="https://github.com/routewise96/robertium" style="color:var(--accent);">robertium GitHub repository</a>
        under <code style="font-family:var(--font-mono, 'JetBrains Mono', monospace); font-size: 13px; background: var(--bg-section); padding: 1px 5px; border-radius: 3px;">data/submissions/</code>.
        Your name, affiliation, ORCID (if provided), and reasoning will be
        visible publicly — both in the git history and on the rendered
        hypothesis page after approval.
      </p>
      <p>
        Your email and a salted hash of your IP address are stored for
        moderation purposes but are never displayed on the public site.
        Approved hypotheses are credited to you with your name and affiliation
        on the hypothesis page and (when applicable) link to your ORCID.
      </p>
    </div>
  </section>
</Layout>
