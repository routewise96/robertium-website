---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Approach from '../components/Approach.astro';
import Open from '../components/Open.astro';
import FeaturedHypotheses from '../components/FeaturedHypotheses.astro';
import Contact from '../components/Contact.astro';
import Subscribe from '../components/Subscribe.astro';
---
<Layout
  title="Robertium — Open-source drug repurposing discovery"
  description="Open-source infrastructure for literature-based drug repurposing discovery. 7,957 cross-domain hypotheses across six therapeutic areas, with full evidence chains from 99,000+ biomedical papers."
  current="home"
  ogImage="/og/home.png"
>
  <Hero />
  <Problem />
  <Approach />
  <Open />
  <FeaturedHypotheses />
  <Contact />
  <Subscribe />
</Layout>
