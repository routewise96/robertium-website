---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import PredictionsBanner from '../components/PredictionsBanner.astro';
import BrowseThreeWays from '../components/BrowseThreeWays.astro';
import Problem from '../components/Problem.astro';
import Approach from '../components/Approach.astro';
import Open from '../components/Open.astro';
import FeaturedHypotheses from '../components/FeaturedHypotheses.astro';
import Contact from '../components/Contact.astro';
import Subscribe from '../components/Subscribe.astro';
---
<Layout
  title="Robertium — Open-source drug repurposing discovery"
  description="Open-source infrastructure for literature-based drug repurposing discovery. 24,285 cross-domain hypotheses across ten therapeutic areas, with full evidence chains from 167,000+ biomedical papers."
  current="home"
  ogImage="/og/home.png"
>
  <Hero />
  <aside class="digest-strip">
    <div class="container digest-strip__inner">
      <p class="digest-strip__text">
        <span class="digest-strip__pulse" aria-hidden="true"></span>
        <strong>What's new this week:</strong>
        live discovery signals — top movers, recruiting trials, featured cases.
      </p>
      <a class="digest-strip__cta" href="/digest">Open the digest →</a>
    </div>
  </aside>
  <PredictionsBanner />
  <BrowseThreeWays />
  <Problem />
  <Approach />
  <Open />
  <section class="section section--gray prov-callout">
    <div class="container--narrow prov-callout__inner">
      <p class="prov-callout__eyebrow">Audit-grade transparency</p>
      <h2 class="prov-callout__heading">Every hypothesis has a full provenance trace</h2>
      <p class="prov-callout__sub">
        Source papers, extracted claims, scoring code, embedding model, prompt version,
        and the exact pipeline run that produced the row. Downloadable JSON. No black boxes.
      </p>
      <p class="prov-callout__cta-row">
        <a class="prov-callout__cta" href="/hypothesis/37636/">See an example trace →</a>
        <a class="prov-callout__link" href="/method/#provenance">How it works</a>
      </p>
    </div>
  </section>
  <FeaturedHypotheses />
  <Contact />
  <Subscribe />
</Layout>

<style>
  .digest-strip {
    background: linear-gradient(180deg, rgba(8,145,178,0.06) 0%, rgba(8,145,178,0.02) 100%);
    border-top: 1px solid var(--border, #e5e7eb);
    border-bottom: 1px solid var(--border, #e5e7eb);
    padding: 0.75rem 0;
  }
  .digest-strip__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
  }
  .digest-strip__text {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-secondary, #4b5563);
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
  }
  .digest-strip__text strong { color: var(--text, #1f2937); font-weight: 600; }
  .digest-strip__pulse {
    display: inline-block;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--accent, #0891b2);
    box-shadow: 0 0 0 0 rgba(8,145,178, 0.6);
    animation: digestPulse 1.8s ease-out infinite;
  }
  @keyframes digestPulse {
    0%   { box-shadow: 0 0 0 0 rgba(8,145,178, 0.55); }
    70%  { box-shadow: 0 0 0 0.55rem rgba(8,145,178, 0); }
    100% { box-shadow: 0 0 0 0 rgba(8,145,178, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .digest-strip__pulse { animation: none; }
  }
  .digest-strip__cta {
    color: var(--accent, #0891b2);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }
  .digest-strip__cta:hover { text-decoration: underline; }

  .prov-callout__inner {
    text-align: center;
    padding: 1rem 0;
  }
  .prov-callout__eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin: 0 0 0.5rem;
  }
  .prov-callout__heading {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.75rem;
  }
  .prov-callout__sub {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 38rem;
    margin: 0 auto 1.5rem;
    line-height: 1.55;
  }
  .prov-callout__cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem 1.5rem;
    margin: 0;
  }
  .prov-callout__cta {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .prov-callout__cta:hover { background: var(--accent-hover, #0e7490); }
  .prov-callout__link {
    color: var(--text-secondary);
    font-size: 0.9rem;
    text-decoration: none;
  }
  .prov-callout__link:hover { color: var(--accent); text-decoration: underline; }
</style>
