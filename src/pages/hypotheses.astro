---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

const dataPath = path.join(process.cwd(), 'public', 'data', 'hypotheses.json');
const raw = fs.readFileSync(dataPath, 'utf-8');
const data = JSON.parse(raw) as {
  metadata: {
    generated_at: string;
    total_count: number;
    domains: string[];
    evidence_papers: number;
    schema_version: string;
  };
  hypotheses: Array<{
    id: number;
    drug: string;
    drug_domain: string | null;
    predicate_ab: string | null;
    mediator: string;
    mediator_type: string | null;
    predicate_bc: string | null;
    outcome: string;
    outcome_domain: string | null;
    score: number | null;
    ab_count: number | null;
    bc_count: number | null;
    direct_count: number | null;
    evidence: {
      ab: Array<{ pmid: string; title: string; year: number | null }>;
      bc: Array<{ pmid: string; title: string; year: number | null }>;
    };
  }>;
};

const drugDomains = Array.from(
  new Set(data.hypotheses.map((h) => h.drug_domain).filter(Boolean))
).sort() as string[];
const outcomeDomains = Array.from(
  new Set(data.hypotheses.map((h) => h.outcome_domain).filter(Boolean))
).sort() as string[];

const domainPairs = new Set(
  data.hypotheses.map((h) => `${h.drug_domain ?? ''}→${h.outcome_domain ?? ''}`)
);

const allDomains = Array.from(new Set([...drugDomains, ...outcomeDomains])).sort();
const DOMAIN_LABEL: Record<string, string> = {
  als: 'ALS',
  alzheimer: "Alzheimer's",
  depression: 'Depression (MDD)',
  epilepsy: 'Epilepsy',
  glioblastoma: 'Glioblastoma',
  pancreatic_cancer: 'Pancreatic cancer',
};
const domainCounts = allDomains
  .map((d) => ({
    key: d,
    label: DOMAIN_LABEL[d] ?? d,
    count: data.hypotheses.filter(
      (h) => h.drug_domain === d || h.outcome_domain === d,
    ).length,
  }))
  .sort((a, b) => b.count - a.count);

const highCount = data.hypotheses.filter(
  (h) => (h as any).outreach_quality === 'high',
).length;

const novelCount = data.hypotheses.filter(
  (h) => (h as any).literature_status === 'novel_signal',
).length;
const noTrialNovelCount = data.hypotheses.filter(
  (h) =>
    (h as any).literature_status === 'novel_signal' &&
    ((h as any).clinical_trial_status === 'none' || (h as any).clinical_trial_status == null),
).length;
---
<Layout
  title="Drug Repurposing Hypotheses — Cross-domain Catalog"
  description="Browse drug repurposing candidates discovered through literature-based discovery. 7,957 cross-domain hypotheses across six therapeutic domains and 30 directional pairs (640 outreach-quality after deduplication, 56 high-confidence), with full evidence chains from PubMed."
  current="hypotheses"
  ogImage="/og/hypotheses.png"
>
  <section class="hyp-hero">
    <div class="container">
      <h1>Drug repurposing hypotheses</h1>
      <p class="subtitle">
        Cross-domain candidates discovered through literature-based discovery.
        Each hypothesis is a chain of evidence from peer-reviewed papers.
      </p>
      <p class="meta">
        <strong>{data.metadata.total_count}</strong> hypotheses across
        <strong>{domainPairs.size}</strong> domain pairs
        ({data.metadata.domains.join(' ↔ ')}),
        backed by <strong>{data.metadata.evidence_papers}</strong> evidence papers
      </p>
    </div>
  </section>

  <section class="hyp-callout">
    <div class="container">
      <h2 class="hyp-callout-title">Start here: {highCount} high-confidence hypotheses</h2>
      <p class="hyp-callout-body">
        These are hypotheses where multiple independent papers support both legs of the chain
        (drug → mediator and mediator → outcome) and the mediator is a specific biological
        entity rather than a generic pathway. They are the strongest candidates for further
        investigation.
      </p>
      <div class="hyp-callout-actions">
        <button type="button" id="hyp-show-high" class="btn btn--primary hyp-callout-btn">
          Show high-confidence only ({highCount})
        </button>
        <button type="button" id="hyp-show-novel" class="btn btn--secondary hyp-callout-btn">
          Show novel signals only ({novelCount})
        </button>
      </div>
      <p class="hyp-callout-foot">
        <strong>{noTrialNovelCount}</strong> hypotheses combine a novel literature signal with no existing
        clinical trial — the candidates Robertium surfaced that no one has investigated yet.
      </p>
    </div>
  </section>

  <section class="hyp-browse">
    <div class="container">
      <h2 class="hyp-browse-title">Browse by therapeutic area</h2>
      <p class="hyp-browse-sub">
        Counts include hypotheses where the domain is either drug source or outcome,
        so a single hypothesis is counted under two domains.
      </p>
      <div class="hyp-browse-grid">
        {domainCounts.map((d) => (
          <button
            type="button"
            class="hyp-browse-tile"
            data-domain={d.key}
          >
            <span class="hyp-browse-tile-label">{d.label}</span>
            <span class="hyp-browse-tile-count">{d.count.toLocaleString()} hypotheses</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <div class="hyp-filters">
    <div class="container">
      <div class="hyp-filters-grid">
        <input
          type="search"
          id="hyp-search"
          class="hyp-input"
          placeholder="Search by drug, gene, protein, or disease…"
          aria-label="Search hypotheses"
          autocomplete="off"
        />
        <select id="hyp-drug-domain" class="hyp-select" aria-label="Drug domain">
          <option value="">All drug domains</option>
          {drugDomains.map((d) => <option value={d}>{d}</option>)}
        </select>
        <select id="hyp-outcome-domain" class="hyp-select" aria-label="Outcome domain">
          <option value="">All outcome domains</option>
          {outcomeDomains.map((d) => <option value={d}>{d}</option>)}
        </select>
        <select id="hyp-sort" class="hyp-select" aria-label="Sort">
          <option value="score-desc">Score (high to low)</option>
          <option value="score-asc">Score (low to high)</option>
          <option value="evidence-desc">Evidence count</option>
        </select>
        <label class="hyp-checkbox">
          <input type="checkbox" id="hyp-multi" />
          Multi-evidence
        </label>
        <label class="hyp-checkbox">
          <input type="checkbox" id="hyp-high" />
          High-confidence only
        </label>
        <label class="hyp-checkbox">
          <input type="checkbox" id="hyp-novel" />
          Novel signals only
        </label>
        <button type="button" id="hyp-reset" class="hyp-reset">Reset</button>
      </div>
    </div>
  </div>

  <div class="container">
    <p id="hyp-counter" class="hyp-status">Showing 0 of 0 hypotheses</p>
    <table class="hyp-table" id="hyp-table">
      <thead>
        <tr>
          <th class="num">#</th>
          <th>Drug</th>
          <th></th>
          <th>Mediator</th>
          <th></th>
          <th>Outcome</th>
          <th>Validation</th>
          <th class="num">Score</th>
          <th class="num">Evidence</th>
        </tr>
      </thead>
      <tbody id="hyp-tbody">
        <tr id="hyp-load-trigger" aria-hidden="true">
          <td colspan="9" style="padding: 20px; text-align: center; color: var(--text-muted); font-size: 13px;">
            Loading more…
          </td>
        </tr>
      </tbody>
    </table>
    <div id="hyp-empty" class="hyp-empty" hidden>
      No hypotheses match your filters. Try a different search or
      <button type="button" id="hyp-empty-reset" class="hyp-reset" style="display:inline-block; margin-left:6px;">reset filters</button>.
    </div>
  </div>

  <script
    type="application/json"
    id="hyp-data"
    set:html={JSON.stringify(data.hypotheses)}
  />

  <script is:inline>
    (() => {
      const PAGE_SIZE = 100;
      const HYPOTHESES = JSON.parse(document.getElementById('hyp-data').textContent);

      const $ = (id) => document.getElementById(id);
      const search = $('hyp-search');
      const drugDomain = $('hyp-drug-domain');
      const outcomeDomain = $('hyp-outcome-domain');
      const sortBy = $('hyp-sort');
      const multi = $('hyp-multi');
      const highOnly = $('hyp-high');
      const novelOnly = $('hyp-novel');
      const showHighBtn = $('hyp-show-high');
      const showNovelBtn = $('hyp-show-novel');
      const reset = $('hyp-reset');
      const emptyReset = $('hyp-empty-reset');
      const tbody = $('hyp-tbody');
      const trigger = $('hyp-load-trigger');
      const counter = $('hyp-counter');
      const empty = $('hyp-empty');
      const table = $('hyp-table');
      const browseTiles = document.querySelectorAll('.hyp-browse-tile');
      const SHARE_ORIGIN = 'https://robertium.com';

      let filtered = [];
      let currentRendered = 0;
      let openId = null;

      const escapeHtml = (s) =>
        String(s ?? '').replace(/[&<>"']/g, (c) => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
        })[c]);

      const domainTagClass = (d) => {
        if (!d) return '';
        if (d === 'glioblastoma') return ' hyp-domain-tag--gbm';
        if (d === 'epilepsy') return ' hyp-domain-tag--epi';
        return '';
      };

      const domainTag = (d) =>
        d ? `<span class="hyp-domain-tag${domainTagClass(d)}">${escapeHtml(d)}</span>` : '';

      const TRIAL_BADGE = {
        active: { cls: 'hyp-badge--trial-active', label: 'trial active' },
        completed: { cls: 'hyp-badge--trial-completed', label: 'trial completed' },
        preclinical_only: { cls: 'hyp-badge--trial-pre', label: 'preclinical' },
        none: { cls: 'hyp-badge--trial-none', label: 'no trial' },
      };
      const LIT_BADGE = {
        novel_signal: { cls: 'hyp-badge--lit-novel', label: 'novel' },
        partial_evidence: { cls: 'hyp-badge--lit-partial', label: 'partial' },
        reproduces_known: { cls: 'hyp-badge--lit-known', label: 'known' },
      };
      // Top novel case studies — link badge from catalog row to deep-dive page.
      // Benchmark hits (5385, 23443) intentionally not featured here.
      const FEATURED_CASE_STUDIES = {
        7049: 'carbamazepine-kras-pancreatic-cancer',
        3772: 'curcumin-tdp43-als',
        2091: 'ketogenic-diet-sod1-als',
      };
      const trialBadge = (s) => {
        const b = TRIAL_BADGE[s];
        return b ? `<span class="hyp-badge ${b.cls}">${b.label}</span>` : '';
      };
      const litBadge = (s) => {
        const b = LIT_BADGE[s];
        return b ? `<span class="hyp-badge ${b.cls}">${b.label}</span>` : '';
      };
      const featuredBadge = (id) => {
        const slug = FEATURED_CASE_STUDIES[id];
        return slug
          ? `<a class="hyp-badge hyp-badge--featured" href="/case-studies/${slug}/" title="Featured case study">★ featured</a>`
          : '';
      };

      const renderRow = (h, index) => {
        const score = h.score != null ? h.score.toFixed(3) : '—';
        const evidence = `${h.ab_count ?? 0} + ${h.bc_count ?? 0}`;
        const badges = `${featuredBadge(h.id)}${trialBadge(h.clinical_trial_status)}${litBadge(h.literature_status)}`;
        let html = `
          <tr class="hyp-row" data-id="${h.id}">
            <td class="num">${index + 1}</td>
            <td class="drug">${escapeHtml(h.drug)}${domainTag(h.drug_domain)}</td>
            <td class="arrow">→</td>
            <td class="mediator">${escapeHtml(h.mediator)}</td>
            <td class="arrow">→</td>
            <td class="outcome">${escapeHtml(h.outcome)}${domainTag(h.outcome_domain)}</td>
            <td class="hyp-validation-cell">${badges}</td>
            <td class="num score">${score}</td>
            <td class="num evidence">${evidence}</td>
          </tr>`;
        if (h.id === openId) html += renderDetail(h);
        return html;
      };

      const renderDetail = (h) => {
        const pubmedUrl = (pmid) => `https://pubmed.ncbi.nlm.nih.gov/${encodeURIComponent(pmid)}/`;
        const evList = (items) =>
          items.length
            ? `<ul class="hyp-evidence-list">${items
                .map(
                  (e) => `
                    <li>
                      <a href="${pubmedUrl(e.pmid)}" target="_blank" rel="noopener">PMID ${escapeHtml(e.pmid)}</a>
                      <span class="ev-title">${escapeHtml(e.title)}</span>${
                        e.year ? ` <span style="color:var(--text-muted)">(${e.year})</span>` : ''
                      }
                    </li>`
                )
                .join('')}</ul>`
            : `<p class="hyp-evidence-empty">No PMID-linked papers in this leg.</p>`;

        const score = h.score != null ? h.score.toFixed(3) : '—';
        const trialDescr = ({
          active: 'A clinical trial for this drug–outcome pair is currently recruiting or active.',
          completed: 'A clinical trial for this drug–outcome pair has been completed, terminated, or withdrawn.',
          preclinical_only: 'A study exists for this pair but is observational or has not started enrolling.',
          none: 'No clinical trial registered on ClinicalTrials.gov for this drug–outcome pair.',
          unknown: 'Drug name not suitable for the trial registry query (combination, identifier, or special characters).',
        })[h.clinical_trial_status] || '';
        const litDescr = ({
          reproduces_known: 'Five or more PubMed papers explicitly discuss this drug as treatment/therapy/repurposing for this outcome — Robertium reproduces a documented association.',
          partial_evidence: 'A handful of PubMed papers mention both the drug and outcome, but the connection is not yet systematic in the literature.',
          novel_signal: 'No PubMed paper explicitly proposes this drug as treatment/therapy/repurposing for this outcome — a candidate worth investigating.',
          unknown: 'Drug name not suitable for the literature query (combination, identifier, or special characters).',
        })[h.literature_status] || '';
        const ncts = (h.clinical_trial_nct_ids || []).slice(0, 3);
        const nctLine = ncts.length
          ? `<div class="hyp-detail-nct">NCT IDs: ${ncts.map(n => `<a href="https://clinicaltrials.gov/study/${encodeURIComponent(n)}" target="_blank" rel="noopener">${escapeHtml(n)}</a>`).join(', ')}</div>`
          : '';
        return `
          <tr class="hyp-detail-row">
            <td colspan="9" class="hyp-detail">
              <div class="hyp-detail-inner">
                <div class="hyp-chain">
                  <span class="chain-node">${escapeHtml(h.drug)}</span>
                  <span class="chain-pred">--[${escapeHtml(h.predicate_ab ?? '?')}]--&gt;</span>
                  <span class="chain-node">${escapeHtml(h.mediator)}</span>
                  <span class="chain-pred">--[${escapeHtml(h.predicate_bc ?? '?')}]--&gt;</span>
                  <span class="chain-node">${escapeHtml(h.outcome)}</span>
                </div>
                <div class="hyp-detail-meta">
                  <span>Score: <strong>${score}</strong></span>
                  <span>Evidence A→B: <strong>${h.ab_count ?? 0}</strong></span>
                  <span>Evidence B→C: <strong>${h.bc_count ?? 0}</strong></span>
                  <span>Direct A→C: <strong>${h.direct_count ?? 0}</strong></span>
                  <span>ID: <strong>${h.id}</strong></span>
                </div>
                <div class="hyp-validation-block">
                  <div class="hyp-validation-row">
                    ${trialBadge(h.clinical_trial_status)}
                    <span class="hyp-validation-text">${escapeHtml(trialDescr)}</span>
                  </div>
                  ${nctLine}
                  <div class="hyp-validation-row">
                    ${litBadge(h.literature_status)}
                    <span class="hyp-validation-text">${escapeHtml(litDescr)}</span>
                  </div>
                </div>
                <div class="hyp-evidence-section">
                  <h4>Evidence: ${escapeHtml(h.drug)} ${escapeHtml(h.predicate_ab ?? '?')} ${escapeHtml(h.mediator)}</h4>
                  ${evList(h.evidence.ab || [])}
                </div>
                <div class="hyp-evidence-section">
                  <h4>Evidence: ${escapeHtml(h.mediator)} ${escapeHtml(h.predicate_bc ?? '?')} ${escapeHtml(h.outcome)}</h4>
                  ${evList(h.evidence.bc || [])}
                </div>
                <button type="button" class="hyp-permalink" data-permalink="${h.id}">
                  Copy permalink
                </button>
              </div>
            </td>
          </tr>`;
      };

      let domainAny = '';

      const computeFiltered = () => {
        const q = (search.value || '').trim().toLowerCase();
        const dd = drugDomain.value;
        const od = outcomeDomain.value;
        const m = multi.checked;
        const hi = highOnly.checked;
        const nv = novelOnly.checked;
        let list = HYPOTHESES.filter((h) => {
          if (dd && h.drug_domain !== dd) return false;
          if (od && h.outcome_domain !== od) return false;
          if (domainAny && h.drug_domain !== domainAny && h.outcome_domain !== domainAny) return false;
          if (hi && h.outreach_quality !== 'high') return false;
          if (nv && h.literature_status !== 'novel_signal') return false;
          if (m && !((h.ab_count || 0) >= 2 || (h.bc_count || 0) >= 2)) return false;
          if (q) {
            const blob = `${h.drug} ${h.mediator} ${h.outcome}`.toLowerCase();
            if (!blob.includes(q)) return false;
          }
          return true;
        });
        const sb = sortBy.value;
        list.sort((a, b) => {
          if (sb === 'score-asc') return (a.score || 0) - (b.score || 0);
          if (sb === 'evidence-desc')
            return ((b.ab_count || 0) + (b.bc_count || 0)) - ((a.ab_count || 0) + (a.bc_count || 0));
          return (b.score || 0) - (a.score || 0);
        });
        return list;
      };

      const updateBrowseTiles = () => {
        browseTiles.forEach((t) => {
          const d = t.getAttribute('data-domain');
          if (d === domainAny) t.classList.add('hyp-browse-tile--active');
          else t.classList.remove('hyp-browse-tile--active');
        });
      };

      const updateCounter = () => {
        counter.textContent = `Showing ${currentRendered} of ${filtered.length} hypotheses`;
      };

      const clearRenderedRows = () => {
        const rows = tbody.querySelectorAll('tr.hyp-row, tr.hyp-detail-row');
        rows.forEach((r) => r.remove());
      };

      const renderNextPage = () => {
        if (currentRendered >= filtered.length) {
          trigger.style.display = 'none';
          updateCounter();
          return;
        }
        const slice = filtered.slice(currentRendered, currentRendered + PAGE_SIZE);
        const html = slice.map((h, i) => renderRow(h, currentRendered + i)).join('');
        trigger.insertAdjacentHTML('beforebegin', html);
        currentRendered += slice.length;
        if (currentRendered >= filtered.length) {
          trigger.style.display = 'none';
        } else {
          trigger.style.display = '';
        }
        updateCounter();
      };

      const renderUntilId = (id) => {
        const idx = filtered.findIndex((h) => h.id === id);
        if (idx < 0) return -1;
        while (currentRendered <= idx && currentRendered < filtered.length) {
          renderNextPage();
        }
        return idx;
      };

      const resetAndRender = () => {
        filtered = computeFiltered();
        clearRenderedRows();
        currentRendered = 0;
        if (!filtered.length) {
          trigger.style.display = 'none';
          empty.hidden = false;
          table.style.display = 'none';
          updateCounter();
          return;
        }
        empty.hidden = true;
        table.style.display = '';
        renderNextPage();
      };

      const debounce = (fn, ms) => {
        let t;
        return (...args) => {
          clearTimeout(t);
          t = setTimeout(() => fn.apply(null, args), ms);
        };
      };

      const updateUrl = () => {
        const params = new URLSearchParams();
        if (openId != null) params.set('id', String(openId));
        if (search.value) params.set('q', search.value);
        if (domainAny) params.set('domain', domainAny);
        if (highOnly.checked) params.set('quality', 'high');
        if (novelOnly.checked) params.set('lit', 'novel');
        const qs = params.toString();
        const url = qs ? `?${qs}` : window.location.pathname;
        history.replaceState(null, '', url);
      };

      const closeOpenDetail = () => {
        const detail = tbody.querySelector('tr.hyp-detail-row');
        if (detail) detail.remove();
      };

      const toggleDetailFor = (id) => {
        if (openId === id) {
          openId = null;
          closeOpenDetail();
          updateUrl();
          return;
        }
        closeOpenDetail();
        openId = id;
        const row = tbody.querySelector(`tr.hyp-row[data-id="${id}"]`);
        if (!row) return;
        const detailHtml = renderDetail(HYPOTHESES.find((h) => h.id === id));
        row.insertAdjacentHTML('afterend', detailHtml);
        updateUrl();
      };

      tbody.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const permaBtn = target.closest('[data-permalink]');
        if (permaBtn) {
          e.stopPropagation();
          const id = permaBtn.getAttribute('data-permalink');
          const link = `${SHARE_ORIGIN}/hypotheses?id=${id}`;
          navigator.clipboard.writeText(link).then(() => {
            permaBtn.textContent = 'Copied!';
            permaBtn.classList.add('hyp-permalink--copied');
            setTimeout(() => {
              permaBtn.textContent = 'Copy permalink';
              permaBtn.classList.remove('hyp-permalink--copied');
            }, 1600);
          });
          return;
        }
        if (target.closest('a')) return;
        const row = target.closest('.hyp-row');
        if (!row) return;
        const id = Number(row.getAttribute('data-id'));
        toggleDetailFor(id);
      });

      const onFilterChange = () => {
        openId = null;
        resetAndRender();
        updateUrl();
      };

      search.addEventListener('input', debounce(onFilterChange, 200));
      drugDomain.addEventListener('change', onFilterChange);
      outcomeDomain.addEventListener('change', onFilterChange);
      sortBy.addEventListener('change', onFilterChange);
      multi.addEventListener('change', onFilterChange);
      highOnly.addEventListener('change', onFilterChange);
      novelOnly.addEventListener('change', onFilterChange);

      browseTiles.forEach((tile) => {
        tile.addEventListener('click', () => {
          const d = tile.getAttribute('data-domain') || '';
          domainAny = domainAny === d ? '' : d;
          updateBrowseTiles();
          onFilterChange();
          // jump to results if the table is below the fold
          const tableEl = document.getElementById('hyp-table');
          if (tableEl) tableEl.scrollIntoView({ block: 'start', behavior: 'smooth' });
        });
      });

      if (showHighBtn) {
        showHighBtn.addEventListener('click', () => {
          highOnly.checked = true;
          novelOnly.checked = false;
          domainAny = '';
          updateBrowseTiles();
          onFilterChange();
          const tableEl = document.getElementById('hyp-table');
          if (tableEl) tableEl.scrollIntoView({ block: 'start', behavior: 'smooth' });
        });
      }
      if (showNovelBtn) {
        showNovelBtn.addEventListener('click', () => {
          novelOnly.checked = true;
          highOnly.checked = false;
          domainAny = '';
          updateBrowseTiles();
          onFilterChange();
          const tableEl = document.getElementById('hyp-table');
          if (tableEl) tableEl.scrollIntoView({ block: 'start', behavior: 'smooth' });
        });
      }

      const doReset = () => {
        search.value = '';
        drugDomain.value = '';
        outcomeDomain.value = '';
        sortBy.value = 'score-desc';
        multi.checked = false;
        highOnly.checked = false;
        novelOnly.checked = false;
        domainAny = '';
        updateBrowseTiles();
        openId = null;
        resetAndRender();
        updateUrl();
      };
      reset.addEventListener('click', doReset);
      emptyReset.addEventListener('click', doReset);

      const observer = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting && currentRendered < filtered.length) {
            renderNextPage();
          }
        },
        { rootMargin: '300px' }
      );
      observer.observe(trigger);

      const params = new URLSearchParams(window.location.search);
      if (params.has('q')) search.value = params.get('q') || '';
      const urlDomain = params.get('domain') || '';
      if (urlDomain) {
        domainAny = urlDomain;
        updateBrowseTiles();
      }
      if (params.get('quality') === 'high') {
        highOnly.checked = true;
      }
      if (params.get('lit') === 'novel') {
        novelOnly.checked = true;
      }
      const urlIdRaw = params.get('id');
      const urlId = urlIdRaw != null ? Number(urlIdRaw) : null;
      if (urlId != null && !Number.isNaN(urlId)) openId = urlId;

      resetAndRender();

      if (openId != null) {
        const idx = renderUntilId(openId);
        if (idx >= 0) {
          requestAnimationFrame(() => {
            const row = tbody.querySelector(`tr.hyp-row[data-id="${openId}"]`);
            if (row) {
              row.scrollIntoView({ block: 'center', behavior: 'smooth' });
              row.classList.add('hyp-row--highlight');
              setTimeout(() => row.classList.remove('hyp-row--highlight'), 2400);
            }
          });
        } else {
          openId = null;
        }
      }
    })();
  </script>
</Layout>
