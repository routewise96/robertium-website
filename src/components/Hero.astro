---
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div>
        <h1 class="hero-h1">Could carbamazepine treat pancreatic cancer?</h1>
        <p class="subtitle">
          Robertium found <strong>334</strong> such cross-domain drug repurposing candidates by analyzing
          <strong>99,132</strong> biomedical papers. None have clinical trials yet. All have evidence chains
          in published literature.
        </p>
        <p class="hero-tagline">Open-source. Reproducible. PubMed-validated.</p>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="hero-stat-num">99,132</div>
            <div class="hero-stat-label">papers<br>ingested</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num">7,957</div>
            <div class="hero-stat-label">hypotheses<br>discovered</div>
          </div>
          <div class="hero-stat hero-stat--accent">
            <div class="hero-stat-num">334</div>
            <div class="hero-stat-label">novel<br>candidates</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num">48</div>
            <div class="hero-stat-label">reproduce<br>active trials</div>
          </div>
        </div>
        <div class="hero-buttons">
          <a href="/hypotheses?lit=novel&ct=none" class="btn btn--primary">
            Browse 334 novel candidates &rarr;
          </a>
          <a href="/method" class="btn btn--secondary">Read the methodology</a>
          <a href="https://github.com/routewise96/robertium" class="btn btn--secondary hero-github">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </div>
      <div class="hero-card">
        <div class="hero-card-label">Example novel candidate</div>
        <pre>{`{
  `}<span class="json-key">"drug"</span>: <span class="json-str">"carbamazepine"</span>,{`
  `}<span class="json-key">"drug_domain"</span>: <span class="json-str">"epilepsy"</span>,{`
  `}<span class="json-key">"mediator"</span>: <span class="json-str">"KRAS"</span>,{`
  `}<span class="json-key">"outcome"</span>: <span class="json-str">"pancreatic ductal adenocarcinoma"</span>,{`
  `}<span class="json-key">"outcome_domain"</span>: <span class="json-str">"pancreatic_cancer"</span>,{`
  `}<span class="json-key">"score"</span>: <span class="json-num">0.300</span>,{`
  `}<span class="json-key">"evidence_papers"</span>: <span class="json-num">4</span>,{`
  `}<span class="json-key">"clinical_trial_status"</span>: <span class="json-str">"none"</span>,{`
  `}<span class="json-key">"literature_status"</span>: <span class="json-str">"novel_signal"</span>{`
}`}</pre>
      </div>
    </div>
  </div>
</section>
