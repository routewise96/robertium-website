    flex: 1 1 auto;
  }
  .prov-paper__title:hover { color: var(--accent, #0891b2); text-decoration: underline; }
  .prov-paper__role-badges {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .prov-role-badge {
    font-size: 0.66rem;
    font-weight: 700;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    white-space: nowrap;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .prov-role-badge--ab { background: #ddd6fe; color: #5b21b6; }
  .prov-role-badge--bc { background: #fce7f3; color: #9d174d; }
  .prov-paper__meta {
    margin-top: 0.4rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--text-muted, #6b7280);
  }
  .prov-paper__meta code {
    font-size: 0.76rem;
    color: var(--text, #1f2937);
  }
