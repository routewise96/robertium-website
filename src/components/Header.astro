---
const { current = '' } = Astro.props;
---
<header class="site-header">
  <div class="container">
    <a href="/" class="logo" aria-label="Robertium home">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1e40af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="4" cy="6" r="2"/><circle cx="20" cy="6" r="2"/><circle cx="4" cy="18" r="2"/><circle cx="20" cy="18" r="2"/><line x1="9.5" y1="10.5" x2="5.5" y2="7.5"/><line x1="14.5" y1="10.5" x2="18.5" y2="7.5"/><line x1="9.5" y1="13.5" x2="5.5" y2="16.5"/><line x1="14.5" y1="13.5" x2="18.5" y2="16.5"/></svg>
      <span>Robertium</span>
    </a>
    <nav class="site-nav" aria-label="Main navigation">
      <a href="https://github.com/routewise96/robertium">GitHub</a>
      <a href="/hypotheses" aria-current={current === 'hypotheses' ? 'page' : undefined}>Hypotheses</a>
      <a href="/method" aria-current={current === 'method' ? 'page' : undefined}>Method</a>
      <a href="/data" aria-current={current === 'data' ? 'page' : undefined}>Data</a>
      <a href="/about" aria-current={current === 'about' ? 'page' : undefined}>About</a>
      <a href="/faq" aria-current={current === 'faq' ? 'page' : undefined}>FAQ</a>
      <a href={current === 'home' ? '#contact' : '/#contact'}>Contact</a>
    </nav>
  </div>
</header>
