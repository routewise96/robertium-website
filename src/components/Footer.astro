---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo" aria-label="Robertium home">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1e40af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="4" cy="6" r="2"/><circle cx="20" cy="6" r="2"/><circle cx="4" cy="18" r="2"/><circle cx="20" cy="18" r="2"/><line x1="9.5" y1="10.5" x2="5.5" y2="7.5"/><line x1="14.5" y1="10.5" x2="18.5" y2="7.5"/><line x1="9.5" y1="13.5" x2="5.5" y2="16.5"/><line x1="14.5" y1="13.5" x2="18.5" y2="16.5"/></svg>
          <span>Robertium</span>
        </a>
        <p>Open-source infrastructure for literature-based drug discovery.</p>
      </div>
      <div class="footer-col">
        <h3>Navigate</h3>
        <ul>
          <li><a href="https://github.com/routewise96/robertium">GitHub</a></li>
          <li><a href="/hypotheses">Hypotheses</a></li>
          <li><a href="/method">Method</a></li>
          <li><a href="/data">Data</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Project</h3>
        <ul>
          <li><a href="https://github.com/routewise96/robertium/blob/main/LICENSE">MIT License</a></li>
          <li><a href="https://github.com/routewise96/robertium">Source Code</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-copy">&copy; {year} Robertium. Open source under MIT License.</div>
  </div>
</footer>
