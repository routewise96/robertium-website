---
import fs from 'node:fs';
import path from 'node:path';

interface Hypothesis {
  id: number;
  drug: string;
  drug_type: string | null;
  drug_domain: string | null;
  predicate_ab: string | null;
  mediator: string;
  mediator_type: string | null;
  predicate_bc: string | null;
  outcome: string;
  outcome_type: string | null;
  outcome_domain: string | null;
  score: number | null;
  filter_reason: string | null;
  outreach_score: number | null;
  outreach_quality: 'high' | 'mid' | 'low' | 'excluded' | null;
  ab_count: number | null;
  bc_count: number | null;
  direct_count: number | null;
}

const dataPath = path.join(process.cwd(), 'public', 'data', 'hypotheses.json');
const raw = fs.readFileSync(dataPath, 'utf-8');
const data = JSON.parse(raw) as { hypotheses: Hypothesis[] };

const baseFilter = (h: Hypothesis) =>
  h.direct_count === 0 &&
  h.drug_domain &&
  h.outcome_domain &&
  h.drug_domain !== h.outcome_domain;

const sortByOutreach = (a: Hypothesis, b: Hypothesis) =>
  (b.outreach_score ?? 0) - (a.outreach_score ?? 0);

const highQuality = data.hypotheses
  .filter((h) => h.outreach_quality === 'high' && baseFilter(h))
  .sort(sortByOutreach);

const midQuality = data.hypotheses
  .filter((h) => h.outreach_quality === 'mid' && baseFilter(h))
  .sort(sortByOutreach);

// Prefer high-quality picks; if fewer than TARGET diverse picks, top up with mid.
const cleanCrossDomain: Hypothesis[] = [...highQuality, ...midQuality];

const TARGET = 5;

function pickDiverse(pool: Hypothesis[]): Hypothesis[] {
  const picked: Hypothesis[] = [];
  const seenPair = new Set<string>();
  const seenDrug = new Set<string>();
  // Pass 1: unique drug AND unique pair
  for (const h of pool) {
    if (picked.length >= TARGET) break;
    const pair = `${h.drug_domain}->${h.outcome_domain}`;
    if (seenPair.has(pair)) continue;
    if (seenDrug.has(h.drug.toLowerCase())) continue;
    picked.push(h);
    seenPair.add(pair);
    seenDrug.add(h.drug.toLowerCase());
  }
  if (picked.length >= TARGET) return picked;
  // Pass 2: relax drug uniqueness
  for (const h of pool) {
    if (picked.length >= TARGET) break;
    if (picked.includes(h)) continue;
    const pair = `${h.drug_domain}->${h.outcome_domain}`;
    if (seenPair.has(pair)) continue;
    picked.push(h);
    seenPair.add(pair);
  }
  if (picked.length >= TARGET) return picked;
  // Pass 3: relax pair uniqueness (allow up to 2 per pair)
  const pairCount = new Map<string, number>();
  picked.forEach((h) => {
    const k = `${h.drug_domain}->${h.outcome_domain}`;
    pairCount.set(k, (pairCount.get(k) ?? 0) + 1);
  });
  for (const h of pool) {
    if (picked.length >= TARGET) break;
    if (picked.includes(h)) continue;
    const k = `${h.drug_domain}->${h.outcome_domain}`;
    if ((pairCount.get(k) ?? 0) >= 2) continue;
    picked.push(h);
    pairCount.set(k, (pairCount.get(k) ?? 0) + 1);
  }
  return picked;
}

const featured = pickDiverse(cleanCrossDomain);

const DOMAIN_LABEL: Record<string, string> = {
  als: 'ALS',
  alzheimer: "Alzheimer's",
  depression: 'depression',
  epilepsy: 'epilepsy',
  glioblastoma: 'glioblastoma',
  pancreatic_cancer: 'pancreatic cancer',
};

const VOWELS = new Set(['a', 'e', 'i', 'o', 'u']);
const article = (word: string) => (VOWELS.has(word.charAt(0).toLowerCase()) ? 'an' : 'a');

function fixVerb(predicate: string): string {
  const p = predicate.replace(/_/g, ' ');
  // "associated with" → "is associated with" (the only predicate that needs a copula)
  if (p === 'associated with') return 'is associated with';
  return p;
}

function summary(h: Hypothesis): string {
  const drugLabel = DOMAIN_LABEL[h.drug_domain ?? ''] ?? (h.drug_domain ?? '').replace(/_/g, ' ');
  const ab = fixVerb(h.predicate_ab ?? 'modulates');
  const bc = fixVerb(h.predicate_bc ?? 'is associated with');
  return `Suggests ${h.drug} (${article(drugLabel)} ${drugLabel} drug) ${ab} ${h.mediator}, which ${bc} ${h.outcome}.`;
}
---
<section class="section section--gray" id="featured">
  <div class="container">
    <div class="section-header" style="justify-content: center;">
      <div class="section-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
      </div>
      <h2>Featured hypotheses</h2>
    </div>
    <p class="featured-intro">
      Top cross-domain candidates with no prior direct evidence linking drug to outcome —
      surfaced through shared molecular mediators. Each card links to the full evidence chain.
    </p>
    <div class="featured-grid">
      {featured.map((h) => (
        <a class="featured-card" href={`/hypotheses?id=${h.id}`}>
          <div class="featured-chain">
            <span class="featured-node featured-node--drug">{h.drug}</span>
            <span class="featured-arrow">→</span>
            <span class="featured-node featured-node--mediator">{h.mediator}</span>
            <span class="featured-arrow">→</span>
            <span class="featured-node featured-node--outcome">{h.outcome}</span>
          </div>
          <div class="featured-domains">
            <span class="featured-domain-tag">{(h.drug_domain ?? '').replace('_', ' ')}</span>
            <span class="featured-arrow featured-arrow--small">→</span>
            <span class="featured-domain-tag">{(h.outcome_domain ?? '').replace('_', ' ')}</span>
            {h.mediator_type && (
              <span class="featured-meta">via {h.mediator_type}</span>
            )}
          </div>
          <p class="featured-summary">{summary(h)}</p>
          <div class="featured-footer">
            <span class="featured-score">score {((h.outreach_score ?? h.score) ?? 0).toFixed(3)}</span>
            <span class="featured-evidence">
              {h.ab_count ?? 0} + {h.bc_count ?? 0} evidence papers
            </span>
          </div>
        </a>
      ))}
    </div>
    <p class="featured-cta">
      <a href="/hypotheses">Browse all 4,593 cross-domain hypotheses →</a>
    </p>
  </div>
</section>

<style>
  .featured-intro {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 32px;
    color: #4a5568;
    font-size: 16px;
    line-height: 1.7;
  }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 16px;
  }
  .featured-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 20px 22px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color .15s, box-shadow .15s, transform .15s;
  }
  .featured-card:hover {
    border-color: #1e40af;
    box-shadow: 0 4px 12px rgba(30, 64, 175, 0.08);
    transform: translateY(-1px);
  }
  .featured-chain {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px;
    font-size: 15px;
    line-height: 1.5;
  }
  .featured-node { font-weight: 600; color: #0a0a0a; }
  .featured-node--mediator { color: #1e40af; }
  .featured-arrow { color: #cbd5e1; font-size: 13px; padding: 0 2px; }
  .featured-arrow--small { font-size: 11px; }
  .featured-domains {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 12px;
  }
  .featured-domain-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border-radius: 4px;
    background: #f1f5f9;
    color: #475569;
  }
  .featured-meta {
    color: #64748b;
    font-size: 12px;
    margin-left: 4px;
  }
  .featured-summary {
    font-size: 14px;
    color: #4a5568;
    line-height: 1.6;
    margin: 0;
  }
  .featured-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 8px;
    border-top: 1px solid #f1f5f9;
    font-size: 12px;
    color: #64748b;
    font-variant-numeric: tabular-nums;
  }
  .featured-score { font-weight: 600; color: #1e40af; }
  .featured-cta {
    text-align: center;
    margin-top: 28px;
    font-size: 15px;
  }
  .featured-cta a {
    color: #1e40af;
    text-decoration: none;
    font-weight: 500;
  }
  .featured-cta a:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .featured-grid { grid-template-columns: 1fr; }
    .featured-chain { font-size: 14px; }
  }
</style>
